{
  "//": "Place this at .claude/settings.json in the OB_Datavers repo. defaultMode acceptEdits auto-runs file reads/edits; 'ask' forces a prompt for risky/important actions (overrides defaultMode); 'deny' blocks outright. Precedence: deny > ask > allow. Loosen for yourself only via .claude/settings.local.json (gitignored).",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git stash list:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(ls:*)",
      "Bash(pwd)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(tree:*)",
      "Bash(file:*)",
      "Bash(which:*)",
      "Bash(echo:*)",
      "Bash(npm test:*)",
      "Bash(npm run build:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run lint:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git rebase:*)",
      "Bash(git reset:*)",
      "Bash(git revert:*)",
      "Bash(git tag:*)",
      "Bash(git fetch:*)",
      "Bash(rm:*)",
      "Bash(mv:*)",
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm publish:*)",
      "Bash(npx:*)",
      "Bash(pip install:*)",
      "Bash(brew:*)",
      "Bash(az:*)",
      "Bash(docker:*)",
      "Edit(.github/workflows/**)",
      "Write(.github/workflows/**)",
      "Edit(.github/CODEOWNERS)",
      "Edit(.github/dependabot.yml)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(SECURITY.md)",
      "Edit(ARCHITECTURE.md)",
      "Edit(docs/adr/**)",
      "Edit(.gitleaks.toml)",
      "Edit(.gitignore)",
      "Edit(.gitattributes)",
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Bash(sudo:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(chmod 777:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(nc:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Edit(.git/**)",
      "Write(.git/**)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Write(.claude/settings.json)",
      "Write(.claude/settings.local.json)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/local.settings.json)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",
      "Read(.aws/**)",
      "Read(.ssh/**)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)"
    ]
  }
}
